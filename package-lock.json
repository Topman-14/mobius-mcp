{
  "name": "console-stream-mcp",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "console-stream-mcp",
      "license": "MIT",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "devDependencies": {
        "typescript": "^5.6.0"
      },
      "engines": {
        "node": ">=18"
      }
    },
    "apps/browser-extension": {
      "name": "@console-stream-mcp/browser-extension",
      "version": "0.0.1",
      "license": "MIT",
      "dependencies": {
        "@console-stream-mcp/protocol": "0.0.1",
        "@console-stream-mcp/shared-types": "0.0.1"
      }
    },
    "apps/mcp-server": {
      "name": "@console-stream-mcp/mcp-server",
      "version": "0.0.1",
      "license": "MIT",
      "dependencies": {
        "@console-stream-mcp/protocol": "0.0.1",
        "@console-stream-mcp/shared-types": "0.0.1"
      },
      "bin": {
        "console-stream-mcp": "dist/index.js"
      }
    },
    "apps/npm-client": {
      "name": "console-stream-client",
      "version": "0.0.1",
      "license": "MIT",
      "dependencies": {
        "@console-stream-mcp/protocol": "0.0.1",
        "@console-stream-mcp/shared-types": "0.0.1"
      }
    },
    "node_modules/@console-stream-mcp/browser-extension": {
      "resolved": "apps/browser-extension",
      "link": true
    },
    "node_modules/@console-stream-mcp/mcp-server": {
      "resolved": "apps/mcp-server",
      "link": true
    },
    "node_modules/@console-stream-mcp/protocol": {
      "resolved": "packages/protocol",
      "link": true
    },
    "node_modules/@console-stream-mcp/shared-types": {
      "resolved": "packages/shared-types",
      "link": true
    },
    "node_modules/console-stream-client": {
      "resolved": "apps/npm-client",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/protocol": {
      "name": "@console-stream-mcp/protocol",
      "version": "0.0.1",
      "license": "MIT",
      "dependencies": {
        "@console-stream-mcp/shared-types": "0.0.1"
      }
    },
    "packages/shared-types": {
      "name": "@console-stream-mcp/shared-types",
      "version": "0.0.1",
      "license": "MIT"
    }
  }
}
