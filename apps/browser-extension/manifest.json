{
  "manifest_version": 3,
  "name": "console-stream-mcp",
  "version": "0.0.1",
  "description": "Streams browser console/network events to a local console-stream-mcp server for AI coding agents.",
  "permissions": ["webRequest", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content-script.js"],
      "run_at": "document_start"
    }
  ]
}
