{
  "name": "@mobius-mcp/browser-extension",
  "version": "0.0.1",
  "description": "Chromium extension that captures browser runtime events and streams them to a local mobius-mcp server",
  "license": "MIT",
  "private": true,
  "type": "module",
  "dependencies": {
    "@fontsource/monaspace-krypton": "^5.2.5",
    "@phosphor-icons/react": "^2.1.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^2.5.5",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@mobius-mcp/capture-core": "0.0.1",
    "@mobius-mcp/protocol": "0.0.1",
    "@crxjs/vite-plugin": "^2.0.0-beta.31",
    "@tailwindcss/vite": "^4.0.0",
    "@types/chrome": "^0.0.280",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.27.7",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0"
  },
  "scripts": {
    "build": "vite build && node scripts/build-content-scripts.mjs",
    "dev": "vite",
    "watch": "concurrently -n vite,content-scripts -c blue,green \"vite\" \"node scripts/build-content-scripts.mjs --watch\""
  }
}
