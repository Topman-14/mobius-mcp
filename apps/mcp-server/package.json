{
  "name": "mobius-mcp",
  "version": "1.0.0",
  "description": "MCP server exposing live browser runtime events to AI coding agents",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mobius-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": ["dist"],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@mobius-mcp/protocol": "0.0.1",
    "@types/ws": "^8.5.12",
    "tsup": "^8.3.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node18 --clean",
    "watch": "tsup src/index.ts --format esm --target node18 --watch",
    "start": "node dist/index.js"
  }
}
